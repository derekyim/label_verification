# Default extractor — one of: gemini, mock
# Use 'mock' for offline development; it returns a canned fixture instantly.
EXTRACTOR=gemini

# Required when EXTRACTOR=gemini.
# Get one at https://aistudio.google.com/app/apikey — create the key in a NEW
# project (not an existing GCP project) to ensure free-tier quota is allocated.
GEMINI_API_KEY=

# Optional — override the model. Defaults to gemini-2.0-flash.
# Try gemini-1.5-flash if the default model's quota is exhausted on your key.
# GEMINI_MODEL=gemini-2.0-flash
